rules_version = '2';

// ============================================================
// ALL ACCESS Winnipeg — Non-Profit Community Platform
// Updated: 2026-04-22
//
// ACCESS MODEL:
//   Public      → view events, purchase tickets (full price)
//   Signed-in   → read community feed, purchase tickets
//   Members     → 15% off tickets, post/comment/reply, perks
//   Admin       → full control + delete any content
//
// Custom claims: request.auth.token.role / .status
// Set by Stripe webhook — zero Firestore read cost in rules
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == "admin";
    }

    // Active paying member
    function isActive() {
      return isSignedIn() && request.auth.token.status == "active";
    }

    // Community access — active member OR event ticket purchaser OR manual grant
    // Unlocks: Memories, Albums, Photos, Videos, Community posting
    function hasCommunityAccess() {
      return isAdmin() || isActive() || request.auth.token.hasCommunityAccess == true;
    }

    // Supporting Member — $25/mo subscriber (accountType == "supporter") OR admin
    // Unlocks: Perks, discounts, priority registration, exclusive experiences
    function isSupportingMember() {
      return isAdmin() || isActive() || request.auth.token.accountType == "supporter";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function writingProtectedFields() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(["role", "status", "stripeCustomerId", "stripeSubscriptionId",
                 "stripeCurrentPeriodEnd", "stripeCancelAtPeriodEnd"]);
    }

    // Validate post — userId field matches frontend writes
    function validPost() {
      let d = request.resource.data;
      return d.userId == request.auth.uid
          && d.content is string
          && d.content.size() > 0
          && d.content.size() <= 2000
          && d.keys().hasAll(["userId", "content", "createdAt"]);
    }

    // Validate comment — userId field
    function validComment() {
      let d = request.resource.data;
      return d.userId == request.auth.uid
          && d.postId is string
          && d.content is string
          && d.content.size() > 0
          && d.content.size() <= 1000
          && d.keys().hasAll(["userId", "postId", "content", "createdAt"]);
    }

    // Validate reply — userId field
    function validReply() {
      let d = request.resource.data;
      return d.userId == request.auth.uid
          && d.commentId is string
          && d.postId is string
          && d.content is string
          && d.content.size() > 0
          && d.content.size() <= 500
          && d.keys().hasAll(["userId", "commentId", "postId", "content", "createdAt"]);
    }


    // ─── users/{uid} ────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow update: if (isOwner(uid) && !writingProtectedFields()) || isAdmin();
      allow create: if isSignedIn() && isOwner(uid)
                    && request.resource.data.role == "member"
                    && request.resource.data.status == "inactive";
      allow delete: if isAdmin();
    }


    // ─── events/{eventId} ───────────────────────────────────
    // PUBLIC READ — anyone can browse events and purchase tickets
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }


    // ─── perks/{perkId} ─────────────────────────────────────
    // Supporting Members only — perk codes are a $25/mo subscriber benefit
    match /perks/{perkId} {
      allow read: if isAdmin()
                  || (isSupportingMember() && resource.data.status == "active");
      allow create, update, delete: if isAdmin();
    }


    // ─── posts/{postId} ─────────────────────────────────────
    // READ  — signed-in users only (community feed visible to all auth'd users)
    // WRITE — community access (active member OR event attendee OR manual grant)
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if hasCommunityAccess() && validPost();
      allow update: if isAdmin()
                    || (isOwner(resource.data.userId) && hasCommunityAccess()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(["content", "updatedAt"]));
      allow delete: if isAdmin() || (isOwner(resource.data.userId) && hasCommunityAccess());
    }


    // ─── comments/{commentId} ───────────────────────────────
    // READ  — signed-in users only
    // WRITE — community access
    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if hasCommunityAccess() && validComment();
      allow update: if isAdmin()
                    || (isOwner(resource.data.userId) && hasCommunityAccess()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(["content", "updatedAt"]));
      allow delete: if isAdmin() || (isOwner(resource.data.userId) && hasCommunityAccess());
    }


    // ─── replies/{replyId} ──────────────────────────────────
    // READ  — signed-in users only
    // WRITE — community access
    match /replies/{replyId} {
      allow read: if isSignedIn();
      allow create: if hasCommunityAccess() && validReply();
      allow update: if isAdmin()
                    || (isOwner(resource.data.userId) && hasCommunityAccess()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(["content", "updatedAt"]));
      allow delete: if isAdmin() || (isOwner(resource.data.userId) && hasCommunityAccess());
    }


    // ─── ticketOrders/{orderId} ─────────────────────────────
    // Server-side Admin SDK only for writes
    match /ticketOrders/{orderId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update: if false;
      allow delete: if isAdmin();
    }


    // ─── eventPurchases/{purchaseId} ────────────────────────
    // Purpose-built ownership registry — written by webhook (Admin SDK) only
    // purchaseId == orderId from ticketOrders (1:1 mapping)
    // Users can read their own purchases; admins can read all
    // Enables safe client-side ownership queries without ticketOrders complexity
    match /eventPurchases/{purchaseId} {
      // Primary: user reads their own records by UID
      // Fallback: by email — covers edge cases where userId was null at write time
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid)
                  || (isSignedIn() && resource.data.userEmail == request.auth.token.email);
      allow create, update, delete: if false;
    }


    // ─── socialFeed/{postId} ────────────────────────────────
    // PUBLIC READ — anyone can view the social feed
    // WRITE — admin only (managed via /admin/social-feed)
    // Phase 2: server-side sync from Instagram/TikTok API will also write here
    match /socialFeed/{postId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }


    // ─── leads/{leadId} ─────────────────────────────────────
    // OpenClaw widget captures public leads (name, email, instagram)
    // Anyone can submit; only admin can read/manage
    match /leads/{leadId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.keys().hasAll(["name", "email", "source", "capturedAt"])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 200;
    }


    // ─── config/{docId} ─────────────────────────────────────
    // Platform sync config, API status, last sync timestamps
    // Admin-only read/write (written by server-side sync route)
    match /config/{docId} {
      allow read, write: if isAdmin();
    }


    // ─── Takers AI Command Center ────────────────────────────
    // All collections admin-only. API routes double-verify via adminAuth().

    match /agents/{agentId} {
      allow read, write: if isAdmin();
    }

    // Agent Instructions — separately editable instructions per agent
    match /agentInstructions/{agentId} {
      allow read, write: if isAdmin();
    }

    match /brandMemory/{memoryId} {
      allow read, write: if isAdmin();
      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    match /promptTemplates/{templateId} {
      allow read, write: if isAdmin();
    }

    match /conversations/{conversationId} {
      allow read, write: if isAdmin();
      match /messages/{messageId} {
        allow read, write: if isAdmin();
      }
    }

    match /savedOutputs/{outputId} {
      allow read, write: if isAdmin();
    }

    match /aiTasks/{taskId} {
      allow read, write: if isAdmin();
    }

    // Workflow run tracking — written by chat route, read-only via API
    match /workflowRuns/{runId} {
      allow read, write: if isAdmin();
    }

    // Workflow definitions — reusable multi-step pipelines
    match /workflowDefinitions/{defId} {
      allow read, write: if isAdmin();
    }

    // Approval queue — pending/approved/rejected admin actions
    match /approvalQueue/{itemId} {
      allow read, write: if isAdmin();
    }

    // Observability — granular per-request agent logs with token usage
    match /agentLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // Feedback logs — admin ratings on agent responses
    match /feedbackLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // Knowledge base — source documents for semantic retrieval
    match /knowledgeBase/{docId} {
      allow read, write: if isAdmin();
    }

    // Knowledge chunks — embedded chunks from knowledgeBase documents
    match /knowledgeChunks/{chunkId} {
      allow read, write: if isAdmin();
    }

    // Pipeline runs — multi-step workflow execution with 9-state machine
    match /pipelineRuns/{runId} {
      allow read, write: if isAdmin();
    }

    // Ingest jobs — knowledge base embedding pipeline tracking
    match /ingestJobs/{jobId} {
      allow read, write: if isAdmin();
    }

    // Tool calls — approval-gated external tool invocations
    match /toolCalls/{callId} {
      allow read, write: if isAdmin();
    }

    // Feedback signals — learning signals from admin interactions
    match /feedbackSignals/{signalId} {
      allow read, write: if isAdmin();
    }

    // Orchestration jobs — async job queue with retry + scheduling
    match /orchestrationJobs/{jobId} {
      allow read, write: if isAdmin();
    }

    // AI role assignments — RBAC for takers-ai system
    match /aiRoles/{uid} {
      allow read, write: if isAdmin();
    }

    // Audit events — immutable execution history and compliance trail
    match /auditEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;  // Immutable — never modified after write
    }

    // Execution checkpoints — enables replay from last completed step
    match /executionCheckpoints/{checkpointId} {
      allow read, write: if isAdmin();
    }

    // Cost events — per-request token + spend tracking
    match /costEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;  // Immutable ledger
    }

    // Rate limits — sliding window counters per uid+route
    match /rateLimits/{docId} {
      allow read, write: if isAdmin();
    }

    // Dead-letter queue — failed jobs requiring human intervention
    match /deadLetterQueue/{itemId} {
      allow read, write: if isAdmin();
    }

    // ── Phase 7: Intelligence Layer ────────────────────────────

    // Execution plans — generated by the strategic planner
    match /executionPlans/{planId} {
      allow read, write: if isAdmin();
    }

    // Reflection logs — quality critique records per agent output
    match /reflectionLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;  // Immutable quality record
    }

    // Improvement signals — self-improvement learning signals
    match /improvementSignals/{signalId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;  // Append-only learning ledger
    }

    // Simulation results — pipeline dry-run results
    match /simulationResults/{simId} {
      allow read, write: if isAdmin();
    }


    // ── Creative & Event Intelligence ─────────────────────────

    // Creative briefs — AI-generated flyer/campaign briefs
    match /creativeBriefs/{briefId} {
      allow read, write: if isAdmin();
    }

    // Image prompts — AI-generated image generation prompts
    match /imagePrompts/{promptId} {
      allow read, write: if isAdmin();
    }

    // Generated assets — saved AI-generated content (copy, prompts, briefs)
    match /generatedAssets/{assetId} {
      allow read, write: if isAdmin();
    }

    // Event facts — verified event data extracted from uploads or manually set
    match /eventFacts/{factId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Event knowledge — structured event intelligence records
    match /eventKnowledge/{knowledgeId} {
      allow read, write: if isAdmin();
    }

    // Fact checks — hallucination validation logs per agent output
    match /factChecks/{checkId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;  // Immutable audit record
    }

    // Brand memory versions (nested under brandMemory — already covered above)
    // Explicitly covered here for new /versions subcollection queries
    match /brandMemory/{memoryId}/versions/{versionId} {
      allow read, write: if isAdmin();
    }


    // ─── memoryAlbums/{albumId} ─────────────────────────────
    // READ  — community access (active member OR event attendee OR manual grant)
    // WRITE — admin only (created via Admin > Memories page)
    match /memoryAlbums/{albumId} {
      allow read: if hasCommunityAccess();
      allow create, update, delete: if isAdmin();
    }


    // ─── memoryMedia/{mediaId} ──────────────────────────────
    // READ  — community access
    // WRITE — admin only for create/delete; community members can toggle likedBy
    match /memoryMedia/{mediaId} {
      allow read: if hasCommunityAccess();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
                    || (hasCommunityAccess()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(["likedBy"]));
    }


    // ─── memoryComments/{commentId} ─────────────────────────
    // READ   — community access
    // CREATE — community access (must own the userId field)
    // DELETE — own comment or admin
    match /memoryComments/{commentId} {
      allow read: if hasCommunityAccess();
      allow create: if hasCommunityAccess()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 1000;
      allow delete: if isAdmin()
                    || (hasCommunityAccess() && resource.data.userId == request.auth.uid);
      allow update: if false;
    }


    // ─── Catch-all ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
