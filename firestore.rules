rules_version = '2';

// ============================================================
// ALL ACCESS Winnipeg — Non-Profit Community Platform
// Updated: 2026-04-21
//
// ACCESS MODEL:
//   Public    → view events, purchase tickets
//   Members   → discounted pricing, perks, community feed
//   Admin     → full control
//
// Custom claims: request.auth.token.role / .status
// Set by Stripe webhook — zero Firestore read cost in rules
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == "admin";
    }

    // Active paying member
    function isActive() {
      return isSignedIn() && request.auth.token.status == "active";
    }

    // Member OR admin — perks/community access
    function isMemberOrAdmin() {
      return isActive() || isAdmin();
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function writingProtectedFields() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(["role", "status", "stripeCustomerId", "stripeSubscriptionId",
                 "stripeCurrentPeriodEnd", "stripeCancelAtPeriodEnd"]);
    }

    function validPost() {
      let d = request.resource.data;
      return d.uid == request.auth.uid
          && d.content is string
          && d.content.size() > 0
          && d.content.size() <= 2000
          && d.keys().hasAll(["uid", "content", "createdAt"]);
    }

    function validComment() {
      let d = request.resource.data;
      return d.uid == request.auth.uid
          && d.postId is string
          && d.content is string
          && d.content.size() > 0
          && d.content.size() <= 1000
          && d.keys().hasAll(["uid", "postId", "content", "createdAt"]);
    }


    // ─── users/{uid} ────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow update: if (isOwner(uid) && !writingProtectedFields()) || isAdmin();
      allow create: if isSignedIn() && isOwner(uid)
                    && request.resource.data.role == "member"
                    && request.resource.data.status == "inactive";
      allow delete: if isAdmin();
    }


    // ─── events/{eventId} ───────────────────────────────────
    // PUBLIC READ — anyone can view and purchase tickets
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }


    // ─── perks/{perkId} ─────────────────────────────────────
    // Members only — perk codes are a membership benefit
    match /perks/{perkId} {
      allow read: if isAdmin()
                  || (isMemberOrAdmin() && resource.data.status == "active");
      allow create, update, delete: if isAdmin();
    }


    // ─── posts/{postId} ─────────────────────────────────────
    // Community feed — members only
    match /posts/{postId} {
      allow read: if isMemberOrAdmin();
      allow create: if isActive() && validPost();
      allow update: if isAdmin()
                    || (isOwner(resource.data.uid) && isActive()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(["content", "updatedAt"]));
      allow delete: if isAdmin() || (isOwner(resource.data.uid) && isActive());
    }


    // ─── comments/{commentId} ───────────────────────────────
    match /comments/{commentId} {
      allow read: if isMemberOrAdmin();
      allow create: if isActive() && validComment();
      allow update: if isAdmin()
                    || (isOwner(resource.data.uid) && isActive()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(["content", "updatedAt"]));
      allow delete: if isAdmin() || (isOwner(resource.data.uid) && isActive());
    }


    // ─── ticketOrders/{orderId} ─────────────────────────────
    // Server-side Admin SDK only for writes
    match /ticketOrders/{orderId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update: if false;
      allow delete: if isAdmin();
    }


    // ─── Catch-all ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
