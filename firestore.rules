rules_version = '2';

// ============================================================
// ALL ACCESS by TakersLifestyle — Firestore Security Rules
// Production-grade. Updated: 2026-04-11
//
// GATING MODEL:
//   request.auth.token.role   → "admin" | "member"  (custom claim, no read cost)
//   request.auth.token.status → "active" | "inactive" | "past_due" | "cancelled"
//
// Custom claims are set by the Stripe webhook Cloud Function the moment
// a subscription activates, cancels, or changes. This avoids a get()
// read on every security check — keeping reads cheap and latency low.
//
// COLLECTIONS:
//   users/      — one doc per Firebase Auth uid
//   events/     — platform events (admin writes, members read)
//   perks/      — member perks (admin writes, active members read)
//   posts/      — community feed (active members read/write)
//   comments/   — post comments (active members read/write)
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────

    // Signed in with a verified Firebase Auth token
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin via custom claim (set by webhook — zero extra reads)
    function isAdmin() {
      return isSignedIn() && request.auth.token.role == "admin";
    }

    // Active paying member via custom claim
    function isActive() {
      return isSignedIn() && request.auth.token.status == "active";
    }

    // Active OR admin — full platform access
    function hasFullAccess() {
      return isActive() || isAdmin();
    }

    // Owns this specific document
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Fields the requesting user is NOT allowed to touch
    // (prevents members from escalating their own role or status)
    function writingProtectedFields() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(["role", "status", "stripeCustomerId", "stripeSubscriptionId",
                 "stripeCurrentPeriodEnd", "stripeCancelAtPeriodEnd"]);
    }

    // Content validation helpers
    function validPost() {
      let d = request.resource.data;
      return d.uid == request.auth.uid
          && d.content is string
          && d.content.size() > 0
          && d.content.size() <= 2000
          && d.keys().hasAll(["uid", "content", "createdAt"]);
    }

    function validComment() {
      let d = request.resource.data;
      return d.uid == request.auth.uid
          && d.postId is string
          && d.content is string
          && d.content.size() > 0
          && d.content.size() <= 1000
          && d.keys().hasAll(["uid", "postId", "content", "createdAt"]);
    }


    // ─────────────────────────────────────────────────────────
    // users/{uid}
    //
    // CREATE  → only on first sign-in (handled server-side by webhook,
    //           not by client — but this rule allows it safely)
    // READ    → own doc only, or admin
    // UPDATE  → own doc (safe fields only) or admin (all fields)
    // DELETE  → admin only
    // ─────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // Members can update only safe profile fields (displayName, etc.)
      // Admins can update anything including role/status
      allow update: if isOwner(uid) && !writingProtectedFields()
                    || isAdmin();

      // New user documents are created server-side (Stripe webhook / Cloud Function)
      // This rule allows it to succeed if triggered via authenticated client (onboarding flow)
      allow create: if isSignedIn() && isOwner(uid)
                    && request.resource.data.role == "member"
                    && request.resource.data.status == "inactive";

      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────────────────
    // events/{eventId}
    //
    // READ    → active members + admins get full doc
    //           Public (non-member) events (isMembersOnly == false) are
    //           readable by anyone authenticated — teaser data served
    //           server-side for unauthenticated visitors
    // WRITE   → admins only
    // ─────────────────────────────────────────────────────────
    match /events/{eventId} {
      // Full read: active members and admins
      // Limited read: authenticated users for non-member-only events
      allow read: if hasFullAccess()
                  || (isSignedIn() && resource.data.isMembersOnly == false)
                  || isAdmin();

      allow create, update, delete: if isAdmin();
    }


    // ─────────────────────────────────────────────────────────
    // perks/{perkId}
    //
    // READ    → active members (active status only) + admins
    // WRITE   → admins only
    // Note: inactive perks are hidden by rule, not just UI
    // ─────────────────────────────────────────────────────────
    match /perks/{perkId} {
      allow read: if isAdmin()
                  || (isActive() && resource.data.status == "active");

      allow create, update, delete: if isAdmin();
    }


    // ─────────────────────────────────────────────────────────
    // posts/{postId}
    //
    // READ    → active members + admins
    // CREATE  → active members (validated: own uid, content limits)
    // UPDATE  → only edit own content/body, no other fields; admins all
    // DELETE  → own post or admin (moderation)
    // ─────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if hasFullAccess();

      allow create: if isActive() && validPost();

      allow update: if isAdmin()
                    || (isOwner(resource.data.uid) && isActive()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasOnly(["content", "updatedAt"]));

      allow delete: if isAdmin() || (isOwner(resource.data.uid) && isActive());
    }


    // ─────────────────────────────────────────────────────────
    // comments/{commentId}
    //
    // Same pattern as posts, scoped to a postId
    // ─────────────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read: if hasFullAccess();

      allow create: if isActive() && validComment();

      allow update: if isAdmin()
                    || (isOwner(resource.data.uid) && isActive()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasOnly(["content", "updatedAt"]));

      allow delete: if isAdmin() || (isOwner(resource.data.uid) && isActive());
    }


    // ─────────────────────────────────────────────────────────
    // Catch-all: deny everything else not explicitly matched
    // ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
