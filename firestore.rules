rules_version = '2';

// ============================================================
// ALL ACCESS Winnipeg — Non-Profit Community Platform
// Updated: 2026-04-22
//
// ACCESS MODEL:
//   Public      → view events, purchase tickets (full price)
//   Signed-in   → read community feed, purchase tickets
//   Members     → 15% off tickets, post/comment/reply, perks
//   Admin       → full control + delete any content
//
// Custom claims: request.auth.token.role / .status
// Set by Stripe webhook — zero Firestore read cost in rules
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == "admin";
    }

    // Active paying member
    function isActive() {
      return isSignedIn() && request.auth.token.status == "active";
    }

    // Member OR admin — community write access
    function isMemberOrAdmin() {
      return isActive() || isAdmin();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function writingProtectedFields() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(["role", "status", "stripeCustomerId", "stripeSubscriptionId",
                 "stripeCurrentPeriodEnd", "stripeCancelAtPeriodEnd"]);
    }

    // Validate post — userId field matches frontend writes
    function validPost() {
      let d = request.resource.data;
      return d.userId == request.auth.uid
          && d.content is string
          && d.content.size() > 0
          && d.content.size() <= 2000
          && d.keys().hasAll(["userId", "content", "createdAt"]);
    }

    // Validate comment — userId field
    function validComment() {
      let d = request.resource.data;
      return d.userId == request.auth.uid
          && d.postId is string
          && d.content is string
          && d.content.size() > 0
          && d.content.size() <= 1000
          && d.keys().hasAll(["userId", "postId", "content", "createdAt"]);
    }

    // Validate reply — userId field
    function validReply() {
      let d = request.resource.data;
      return d.userId == request.auth.uid
          && d.commentId is string
          && d.postId is string
          && d.content is string
          && d.content.size() > 0
          && d.content.size() <= 500
          && d.keys().hasAll(["userId", "commentId", "postId", "content", "createdAt"]);
    }


    // ─── users/{uid} ────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow update: if (isOwner(uid) && !writingProtectedFields()) || isAdmin();
      allow create: if isSignedIn() && isOwner(uid)
                    && request.resource.data.role == "member"
                    && request.resource.data.status == "inactive";
      allow delete: if isAdmin();
    }


    // ─── events/{eventId} ───────────────────────────────────
    // PUBLIC READ — anyone can browse events and purchase tickets
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }


    // ─── perks/{perkId} ─────────────────────────────────────
    // Members only — perk codes are a membership benefit
    match /perks/{perkId} {
      allow read: if isAdmin()
                  || (isMemberOrAdmin() && resource.data.status == "active");
      allow create, update, delete: if isAdmin();
    }


    // ─── posts/{postId} ─────────────────────────────────────
    // READ  — signed-in users only (community is gated behind auth)
    // WRITE — active members and admins only
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isMemberOrAdmin() && validPost();
      allow update: if isAdmin()
                    || (isOwner(resource.data.userId) && isMemberOrAdmin()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(["content", "updatedAt"]));
      allow delete: if isAdmin() || (isOwner(resource.data.userId) && isMemberOrAdmin());
    }


    // ─── comments/{commentId} ───────────────────────────────
    // READ  — signed-in users only
    // WRITE — active members and admins only
    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isMemberOrAdmin() && validComment();
      allow update: if isAdmin()
                    || (isOwner(resource.data.userId) && isMemberOrAdmin()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(["content", "updatedAt"]));
      allow delete: if isAdmin() || (isOwner(resource.data.userId) && isMemberOrAdmin());
    }


    // ─── replies/{replyId} ──────────────────────────────────
    // READ  — signed-in users only
    // WRITE — active members and admins only
    match /replies/{replyId} {
      allow read: if isSignedIn();
      allow create: if isMemberOrAdmin() && validReply();
      allow update: if isAdmin()
                    || (isOwner(resource.data.userId) && isMemberOrAdmin()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(["content", "updatedAt"]));
      allow delete: if isAdmin() || (isOwner(resource.data.userId) && isMemberOrAdmin());
    }


    // ─── ticketOrders/{orderId} ─────────────────────────────
    // Server-side Admin SDK only for writes
    match /ticketOrders/{orderId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update: if false;
      allow delete: if isAdmin();
    }


    // ─── Catch-all ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
